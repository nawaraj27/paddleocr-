# Copy to .env. NEVER commit real secrets.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# PostgreSQL (leave POSTGRES_DB empty to use SQLite for local dev)
POSTGRES_DB=datafast
POSTGRES_USER=datafast
POSTGRES_PASSWORD=datafast
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis / Celery (leave empty to run Celery eagerly in-process)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Gemini (leave empty to use the offline mock extractor)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Uploads
MAX_UPLOAD_MB=15
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf
